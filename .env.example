# ─── Database (docker-compose.prod.yml reads these) ──────────────────────────
POSTGRES_USER=ruptl
POSTGRES_PASSWORD=ganti_password_ini
POSTGRES_DB=ruptl_db

# ─── Domain (tanpa https://) ──────────────────────────────────────────────────
DOMAIN=ruptl.yourdomain.com

# ─── JWT — generate: openssl rand -hex 64 ────────────────────────────────────
JWT_ACCESS_SECRET=ganti_dengan_random_string_panjang
JWT_REFRESH_SECRET=ganti_dengan_random_string_panjang_berbeda
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Seed (akun admin pertama kali) ──────────────────────────────────────────
ADMIN_EMAIL=admin@pln.local
ADMIN_PASSWORD=GantiPasswordIni!
ADMIN_NAME=Administrator

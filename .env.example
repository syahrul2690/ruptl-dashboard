# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ruptl:ruptl_pass@localhost:5432/ruptl_db

# ─── JWT ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── App ─────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Seed (initial admin account) ───────────────────────────────────────
ADMIN_EMAIL=admin@pln.local
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=Administrator
